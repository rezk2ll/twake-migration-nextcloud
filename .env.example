# RabbitMQ connection URL
RABBITMQ_URL="amqp://user:pass@localhost:5672"

# Optional topology overrides. Defaults match the contract the Stack
# publishes on; only change them if the surrounding environment has its
# own naming convention. Empty values fall back to the defaults.
#RABBITMQ_EXCHANGE="migration"
#RABBITMQ_REQUEST_ROUTING_KEY="nextcloud.migration.requested"
#RABBITMQ_REQUEST_QUEUE="migration.nextcloud.commands"
#RABBITMQ_CANCEL_ROUTING_KEY="nextcloud.migration.canceled"
#RABBITMQ_CANCEL_QUEUE="migration.nextcloud.cancels"

# Cloudery base URL and API token (for obtaining Stack tokens)
CLOUDERY_URL="https://manager.cozycloud.cc"
CLOUDERY_TOKEN="your-cloudery-api-token"

# URL scheme used when addressing the target Cozy Stack (default: https).
# Set to `http` for local development against a non-TLS Stack.
STACK_URL_SCHEME="https"

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL="info"

# Number of files between progress flushes to the CouchDB tracking document
# (default: 25). This is a file count, not a duration — there is no time-based
# flush. Batching avoids a read-modify-write per file; a final flush always
# runs on completion/failure. See docs/configuration.md for the tradeoff.
FLUSH_INTERVAL="25"
